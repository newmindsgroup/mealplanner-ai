# ============================================================================
# MealPlan Assistant - Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit your .env file to version control
# ============================================================================

# --- Frontend (Vite) ---

# AI API Keys (at least one required for AI features)
# Get yours at: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=

# Get yours at: https://console.anthropic.com/
# If both are set, Anthropic is preferred
VITE_ANTHROPIC_API_KEY=

# Backend API URL (set this when running full-stack)
# Leave empty to run in standalone/mock mode
VITE_API_URL=http://localhost:3001/api

# --- Backend (Node.js/Express) ---

# Server Configuration
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# MySQL Database
DATABASE_HOST=localhost
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_NAME=mealplan_assistant

# JWT Authentication
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# Encryption Key (for storing user API keys securely)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_TO_A_32_CHAR_HEX_KEY

# SMTP Email (optional — for email notifications and password resets)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@mealplan.app

# Server-side AI Keys (optional — users can provide their own)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER=anthropic

# File Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads

# --- NourishAI Intelligence Layer ---

# NourishAI Swarm URL (multi-agent intelligence)
# This is the URL of the NourishAI sidecar service
NOURISH_SWARM_URL=http://localhost:8000

# USDA FoodData Central API Key (free)
# Get yours at: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=

# Web Search API Key (for research agent)
# Used for PubMed and clinical literature searches
SEARCH_API_KEY=

# Google AI Studio Key (optional — for Gemini-based features)
GOOGLE_AI_STUDIO_KEY=

# --- Stripe Billing ---

# Stripe API Keys
# Get yours at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (create products in Stripe Dashboard)
# Pro tier
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
# Family tier
STRIPE_PRICE_FAMILY_MONTHLY=
STRIPE_PRICE_FAMILY_ANNUAL=
# Clinical tier
STRIPE_PRICE_CLINICAL_MONTHLY=
STRIPE_PRICE_CLINICAL_ANNUAL=
